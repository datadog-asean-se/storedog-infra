# Reference ONLY - do not commit real secrets to this repo.
# Create imperatively instead:
#
#   kubectl -n storedog create secret generic storedog-secrets \
#     --from-literal POSTGRES_PASSWORD='<choose-a-password>' \
#     --from-literal DB_PASSWORD='<choose-a-password>'
#
# IMPORTANT: this file intentionally does NOT end in `.yaml`/`.yml`/`.json`. Found
# live during the first real deploy: when this file was named
# `shared-secrets.example.yaml`, ArgoCD's `storedog-app` Application (which
# recursively syncs everything under k8s-manifests/) treated it as a REAL, live
# Secret manifest and, because syncPolicy.automated.selfHeal is true, silently
# overwrote the real imperatively-created `storedog-secrets` with these
# "REPLACE_ME" placeholder values on every sync/refresh - with no error, no
# warning, just a self-healing GitOps loop fighting the real secret. Keep the
# `.yaml.example` extension so ArgoCD's manifest globbing skips this file.
apiVersion: v1
kind: Secret
metadata:
  name: storedog-secrets
  namespace: storedog
type: Opaque
stringData:
  POSTGRES_PASSWORD: "REPLACE_ME"
  DB_PASSWORD: "REPLACE_ME"
