# Reference ONLY - do not commit real values. This is a DIFFERENT secret from the
# Datadog Operator's `datadog-secret` in the `datadog` namespace (api-key/app-key).
# This one lives in the `storedog` namespace and feeds Browser RUM into the frontend:
#
#   kubectl -n storedog create secret generic datadog-secret \
#     --from-literal dd_application_id='<RUM application id>' \
#     --from-literal dd_client_token='<RUM client token>'
#
# IMPORTANT: keep the `.yaml.example` extension (not `.example.yaml`) - see the
# comment in shared-secrets.yaml.example for why. ArgoCD's directory-recurse sync
# only picks up files ending in `.yaml`/`.yml`/`.json`, so this naming keeps it
# from being applied (and self-healed back to placeholder values) as a live Secret.
apiVersion: v1
kind: Secret
metadata:
  name: datadog-secret
  namespace: storedog
type: Opaque
stringData:
  dd_application_id: "REPLACE_ME"
  dd_client_token: "REPLACE_ME"
