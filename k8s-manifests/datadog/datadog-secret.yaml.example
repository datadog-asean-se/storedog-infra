# Reference ONLY - do not commit real keys. Prefer creating the secret imperatively:
#
#   kubectl create namespace datadog
#   kubectl -n datadog create secret generic datadog-secret \
#     --from-literal api-key="$DD_API_KEY" \
#     --from-literal app-key="$DD_APP_KEY"
#
# (An app key is required for Deployment Gates / datadog-ci; see rollouts/.)
#
# IMPORTANT: keep the `.yaml.example` extension (not `.example.yaml`). Found live
# during the first real deploy: this file used to be named
# `datadog-secret.example.yaml`, and because it lives under k8s-manifests/ which
# the `storedog-app` ArgoCD Application syncs with directory.recurse: true and
# selfHeal: true, ArgoCD treated it as a real Secret and continuously overwrote
# the imperatively-created datadog-secret back to these placeholder values - so
# the Datadog Agent silently ran with an invalid API key (APM/logs/metrics all
# 403'd) with no visible error in `kubectl get pods`. Renaming so the file no
# longer ends in `.yaml`/`.yml`/`.json` keeps ArgoCD's manifest globbing from
# picking it up at all.
apiVersion: v1
kind: Secret
metadata:
  name: datadog-secret
  namespace: datadog
type: Opaque
stringData:
  api-key: "REPLACE_WITH_DD_API_KEY"
  app-key: "REPLACE_WITH_DD_APP_KEY"
