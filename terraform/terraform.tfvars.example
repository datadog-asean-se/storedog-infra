# Copy to terraform.tfvars and adjust as needed. All values have sane defaults.
project_id   = "datadog-ese-sandbox"
region       = "asia-southeast1"
zone         = "asia-southeast1-a"
cluster_name = "storedog-adlc-demo"

# Attach to an existing network/subnet. Do NOT create open (0.0.0.0/0) firewall rules.
network    = "default"
subnetwork = "default"

node_machine_type = "e2-standard-4"
node_count        = 2
